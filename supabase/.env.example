# Supabase Edge Functions - Environment Variables Example
# Duplicate this file as .env.test or .env.prod and fill with real values
# Use 'npm run supabase:test:secrets < .env.test' to set them in the cloud

# -- Email (Brevo) --
BREVO_API_KEY=your_brevo_api_key_here
SENDER_EMAIL=contato@seudominio.com.br
SENDER_NAME=Cashways Pass

# -- Platform URLs --
BUBBLE_RESET_URL=https://cashways-pass.bubbleapps.io/version-test/reset_pw

# -- Supabase (Auto-populated by Supabase, but useful to keep track) --
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -- Transfeera (If not hardcoded) --
# TRANSFEERA_CLIENT_ID=...
# TRANSFEERA_CLIENT_SECRET=...
